# Copy this file to .env then fill in real values.
# .env is gitignored — never commit real secrets.

# Postgres
POSTGRES_DB=postgres
POSTGRES_USER=odoo
POSTGRES_PASSWORD=changeme_postgres_password

# Odoo admin master password (used by /web/database/manager endpoint)
ODOO_ADMIN_PASSWD=changeme_admin_password

# Odoo runtime
ODOO_HTTP_PORT=8069
ODOO_LONGPOLLING_PORT=8072

# Public domain (used by nginx server_name + certbot)
ODOO_DOMAIN=erp.example.com
ODOO_LETSENCRYPT_EMAIL=admin@example.com
